{
  "name": "speakeasy-log-browser",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply log-browser-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply log-browser-db",
    "db:seed": "wrangler d1 execute log-browser-db --local --file=./seed.sql"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "wrangler": "^4.0.0"
  }
}
