{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "lib": ["ESNext"],
    "types": ["@cloudflare/workers-types"],
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "@client/*": ["./src/client/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["src/client/**/*", "src/test/**/*"]
}
